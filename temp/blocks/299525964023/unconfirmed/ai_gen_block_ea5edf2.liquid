{% doc %}
  @prompt
    Create a feature highlights section for a product page with a dark premium aesthetic. The section should display 3-4 product features in a horizontal row, each with an icon (SVG or emoji), a bold heading, and a short description beneath it. Style it with a dark/black background, off-white text, and gold accent colors to match a premium music gear brand. The section should be responsive and stack vertically on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-highlights-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_mobile }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-feature-highlights-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }
  }

  .ai-feature-highlights__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-feature-highlights__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-feature-highlights__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.gap_desktop }}px;
    }
  }

  .ai-feature-highlights__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-feature-highlights__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    {% if block.settings.icon_background_enabled %}
      background-color: {{ block.settings.icon_background_color }};
      border-radius: {{ block.settings.icon_border_radius }}px;
      padding: {{ block.settings.icon_padding }}px;
    {% endif %}
  }

  .ai-feature-highlights__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    color: {{ block.settings.icon_color }};
  }

  .ai-feature-highlights__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-feature-highlights__emoji-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
  }

  .ai-feature-highlights__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size_mobile }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0;
    letter-spacing: {{ block.settings.heading_letter_spacing }}%;
    text-transform: {{ block.settings.heading_transform }};
  }

  @media screen and (min-width: 750px) {
    .ai-feature-highlights__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
  }

  .ai-feature-highlights__description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size_mobile }}px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-feature-highlights__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_desktop }}px;
    }
  }
{% endstyle %}

<div class="ai-feature-highlights-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-highlights__container-{{ ai_gen_id }}">
    <div class="ai-feature-highlights__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign feature_enabled_key = 'feature_' | append: i | append: '_enabled'
          assign feature_icon_type_key = 'feature_' | append: i | append: '_icon_type'
          assign feature_icon_key = 'feature_' | append: i | append: '_icon'
          assign feature_emoji_key = 'feature_' | append: i | append: '_emoji'
          assign feature_heading_key = 'feature_' | append: i | append: '_heading'
          assign feature_description_key = 'feature_' | append: i | append: '_description'

          assign feature_enabled = block.settings[feature_enabled_key]
          assign feature_icon_type = block.settings[feature_icon_type_key]
          assign feature_icon = block.settings[feature_icon_key]
          assign feature_emoji = block.settings[feature_emoji_key]
          assign feature_heading = block.settings[feature_heading_key]
          assign feature_description = block.settings[feature_description_key]
        %}

        {% if feature_enabled %}
          <div class="ai-feature-highlights__item-{{ ai_gen_id }}">
            <div class="ai-feature-highlights__icon-wrapper-{{ ai_gen_id }}">
              {% if feature_icon_type == 'emoji' %}
                <div class="ai-feature-highlights__emoji-{{ ai_gen_id }}">
                  {{ feature_emoji }}
                </div>
              {% else %}
                <div class="ai-feature-highlights__icon-{{ ai_gen_id }}">
                  {% case feature_icon %}
                    {% when 'star' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                      </svg>
                    {% when 'shield' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      </svg>
                    {% when 'truck' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                      </svg>
                    {% when 'award' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <circle cx="12" cy="8" r="7"></circle>
                        <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                      </svg>
                    {% when 'check' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    {% when 'heart' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                      </svg>
                    {% when 'zap' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                      </svg>
                    {% when 'music' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M9 18V5l12-2v13"></path>
                        <circle cx="6" cy="18" r="3"></circle>
                        <circle cx="18" cy="16" r="3"></circle>
                      </svg>
                    {% when 'headphones' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
                        <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path>
                      </svg>
                    {% when 'volume' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                      </svg>
                    {% when 'package' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line>
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                      </svg>
                    {% when 'clock' %}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                  {% endcase %}
                </div>
              {% endif %}
            </div>

            {% if feature_heading != blank %}
              <h3 class="ai-feature-highlights__heading-{{ ai_gen_id }}">
                {{ feature_heading }}
              </h3>
            {% endif %}

            {% if feature_description != blank %}
              <p class="ai-feature-highlights__description-{{ ai_gen_id }}">
                {{ feature_description }}
              </p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

