{%- doc -%}
  This component is used to create an accordion (also called as collapsible). It internally uses the "details" HTML
  tag so that it can also be used without any JavaScript.

  @param {string} title - the title to use for the toggle button
  @param {string} content - the hidden content inside the accordion
  @param {string} [icon] - icon name outputted before the title
  @param {string} [custom_icon] - an optional custom icon file outputted before the title
  @param {boolean} [open] - if set to true the accordion is open by default
  @param {boolean} [prose_content] - if set to true, the content is considered as prose and the associated class is added
  @param {boolean} [show_title_as_text] - if set to true the title is shown as text instead of using heading style
  @param {boolean} [show_arrow] - if set to true, the accordion will show an arrow instead of the standard + icon
  @param {string} [size] - can be "sm" or "lg" (if none is passed, the small size is used)
  @param {boolean} [bleed] - if set to true, the accordion will bleed on mobile
  @param {object} [block] - an optional block to output theme editor attributes
  @param {string} [class] - extra class to add on the parent
{%- enddoc -%}

<accordion-disclosure class="accordion {% if size %}accordion--{{ size }}{% endif %} {% if bleed %}bleed sm:unbleed{% endif %} {{ class }}" {{ block.shopify_attributes }}>
  <details
    class="accordion__disclosure group"
    {% if open %}
      open aria-expanded="true"
    {% else %}
      aria-expanded="false"
    {% endif %}
  >
    <summary>
      {%- comment -%}iOS 14 does not support flex on the summary itself, so we have to use this extra div{%- endcomment -%}
      <span class="accordion__toggle {% if show_title_as_text %}text-lg{% else %}h6{% endif %}">
        {%- if custom_icon != blank or icon != 'none' -%}
          <span class="text-with-icon gap-4">
            {%- if custom_icon != blank -%}
              {{- custom_icon | image_url: width: custom_icon.width | image_tag: sizes: '16px', widths: '16,32,48', class: 'constrained-image', style: '--image-max-width: 16px' -}}
            {%- else -%}
              {%- render 'icon' with icon, width: 16 -%}
            {%- endif -%}

            {{- title -}}
          </span>
        {%- else -%}
          <span>{{ title }}</span>
        {%- endif -%}

        {%- if show_arrow -%}
          {%- render 'icon' with 'chevron-down', class: 'group-expanded:rotate' -%}
        {%- else -%}
          <span class="animated-plus group-expanded:rotate" aria-hidden="true"></span>
        {%- endif -%}
      </span>
    </summary>

    <div class="accordion__content {% if prose_content %}prose{% endif %}">
      {{- content -}}
    </div>
  </details>
</accordion-disclosure>
